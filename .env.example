# Copie este arquivo para .env e preencha os valores

PORT=3001

# Segredo para assinar os JWTs — use uma string longa e aleatória em produção
JWT_SECRET=troque_por_uma_string_segura

# String de conexão com o banco de dados
# Exemplos:
#   PostgreSQL: postgresql://user:password@localhost:5432/safecash
#   MySQL:      mysql://user:password@localhost:3306/safecash
#   MongoDB:    mongodb://localhost:27017/safecash
DATABASE_URL=

# Tempo de expiração do token JWT (ex: 7d, 24h, 30m)
JWT_EXPIRES_IN=7d
